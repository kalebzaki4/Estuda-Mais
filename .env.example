# Example Environment Variables
# Copy this file to .env or .env.docker and update with your values

# ===== Frontend =====
VITE_ALLOW_DASHBOARD_WITHOUT_AUTH=true
VITE_API_URL=http://localhost:8080

# ===== Backend / JWT =====
# Generate a strong secret for production
JWT_SECRET=32323232323232323232323232323232323232323232323232323232323232323232323232323232323
SERVER_PORT=8080

# ===== Database =====
# MySQL Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=estuda_mais_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# SPRING Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/estuda_mais_db
SPRING_DATASOURCE_USERNAME=app_user
SPRING_DATASOURCE_PASSWORD=app_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ===== PhpMyAdmin =====
PMA_HOST=mysql
PMA_USER=app_user
PMA_PASSWORD=app_password
PMA_ROOT_PASSWORD=root

